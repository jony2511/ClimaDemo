rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isRoomActive(roomId) {
      return roomDoc(roomId).data.status == 'active';
    }

    function isMember(roomId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    function isHost(roomId) {
      return isSignedIn() && roomDoc(roomId).data.hostUID == request.auth.uid;
    }

    match /rooms/{roomId} {
      allow create: if isSignedIn() && request.resource.data.hostUID == request.auth.uid;
      allow read: if isSignedIn() && (isMember(roomId) || isHost(roomId));
      allow update: if isSignedIn() && (
        isHost(roomId) ||
        (
          isMember(roomId) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastActivityAt', 'playbackState'])
        )
      );
      allow delete: if isHost(roomId);

      match /members/{uid} {
        allow create, update: if isSignedIn() && (
          request.auth.uid == uid ||
          isHost(roomId)
        );
        allow read: if isSignedIn() && (isMember(roomId) || isHost(roomId));
        allow delete: if isSignedIn() && (
          request.auth.uid == uid ||
          isHost(roomId)
        );
      }

      match /queue/{queueItemId} {
        allow read: if isSignedIn() && (isMember(roomId) || isHost(roomId));
        allow create: if isSignedIn() && isMember(roomId) && isRoomActive(roomId);
        allow update, delete: if isHost(roomId);
      }

      match /suggestions/{suggestionId} {
        allow read: if isSignedIn() && (isMember(roomId) || isHost(roomId));
        allow create: if isSignedIn() && isMember(roomId);
        allow update, delete: if isHost(roomId);
      }

      match /skipVotes/{uid} {
        allow read: if isSignedIn() && (isMember(roomId) || isHost(roomId));
        allow create: if isSignedIn() && request.auth.uid == uid && isMember(roomId);
        allow update, delete: if isHost(roomId);
      }
    }
  }
}
